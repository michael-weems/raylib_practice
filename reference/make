#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/bin:/bin:${PATH}"

debug="${1:-}"
reference_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${reference_root}/.." && pwd)"
build_dir="${BUILD_DIR:-"${repo_root}/out/reference-build"}"
if command -v cygpath >/dev/null 2>&1; then
    build_dir="$(cygpath -u "${build_dir}")"
fi
if [[ "${build_dir}" != /* ]]; then
    build_dir="${repo_root}/${build_dir}"
fi
build_type="${BUILD_TYPE:-RelWithDebInfo}"
generator="${CMAKE_GENERATOR:-Ninja}"
compiler="${SW_RENDER_COMPILER:-${COMPILER:-ClangCl}}"

to_windows_path() {
    if command -v cygpath >/dev/null 2>&1; then
        cygpath -w "$1"
    else
        printf '%s' "$1"
    fi
}

repo_root_win="$(to_windows_path "${repo_root}")"
build_dir_win="$(to_windows_path "${build_dir}")"

powershell.exe \
    -NoProfile \
    -ExecutionPolicy Bypass \
    -File "${repo_root_win}\\tools\\build-reference.ps1" \
    -BuildType "${build_type}" \
    -BuildDir "${build_dir_win}" \
    -Generator "${generator}" \
    -Compiler "${compiler}"

binary="${build_dir}/reference_software_renderer.exe"
test -f "${binary}"

if [[ -z "${debug}" ]]; then
    (
        cd "$(dirname "${binary}")"
        "./$(basename "${binary}")"
    )
else
    (
        cd "$(dirname "${binary}")"
        raddbg "$(basename "${binary}")"
    )
fi
