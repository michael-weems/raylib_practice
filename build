#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/bin:/bin:${PATH}"

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
build_dir="${BUILD_DIR:-"${repo_root}/out/build"}"
build_type="${BUILD_TYPE:-Debug}"
generator="${CMAKE_GENERATOR:-Ninja}"
compiler="${SW_RENDER_COMPILER:-${COMPILER:-ClangCl}}"

to_windows_path() {
    if command -v cygpath >/dev/null 2>&1; then
        cygpath -w "$1"
    else
        printf '%s' "$1"
    fi
}

repo_root_win="$(to_windows_path "${repo_root}")"
build_dir_win="$(to_windows_path "${build_dir}")"

powershell.exe \
    -NoProfile \
    -ExecutionPolicy Bypass \
    -File "${repo_root_win}\\tools\\build-src.ps1" \
    -BuildType "${build_type}" \
    -BuildDir "${build_dir_win}" \
    -Generator "${generator}" \
    -Compiler "${compiler}"
